    function calcTimeToCollision(proj, px, py, pvx, pvy, playerRadius) {
        const relVx = Math.cos(proj.angle) * proj.speed - pvx;
        const relVy = Math.sin(proj.angle) * proj.speed - pvy;
        const dx = proj.x - px;
        const dy = proj.y - py;
        
        const a = relVx * relVx + relVy * relVy;
        const b = 2 * (dx * relVx + dy * relVy);
        const radiusSum = proj.radius + playerRadius + dodgeConfig.COLLISION_MARGIN;
        const c = dx * dx + dy * dy - radiusSum * radiusSum;
        
        if (c < 0) return 0;
        if (a < 0.0001) {
            if (Math.abs(b) < 0.0001) return Infinity;
            const t = -c / b;
            return t >= 0 ? t : Infinity;
        }
        
        const discriminant = b * b - 4 * a * c;
        if (discriminant < 0) return Infinity;
        
        const sqrtD = Math.sqrt(discriminant);
        const t1 = (-b - sqrtD) / (2 * a);
        if (t1 >= 0) return t1;
        const t2 = (-b + sqrtD) / (2 * a);
        return t2 >= 0 ? t2 : Infinity;
    }

    function calcApproachDistance(proj, px, py, pvx, pvy) {
        const relVx = Math.cos(proj.angle) * proj.speed - pvx;
        const relVy = Math.sin(proj.angle) * proj.speed - pvy;
        const dx = proj.x - px;
        const dy = proj.y - py;
        
        const denom = relVx * relVx + relVy * relVy;
        if (denom < 0.0001) return {t: 0, distance: Math.hypot(dx, dy)};
        
        const t = Math.max(0, -(dx * relVx + dy * relVy) / denom);
        const projFinalX = proj.x + Math.cos(proj.angle) * proj.speed * t;
        const projFinalY = proj.y + Math.sin(proj.angle) * proj.speed * t;
        const playerFinalX = px + pvx * t;
        const playerFinalY = py + pvy * t;
        
        return {t: t, distance: Math.hypot(projFinalX - playerFinalX, projFinalY - playerFinalY)};
    }

