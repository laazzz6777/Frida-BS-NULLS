            dodgeState.extendedDodgeActive = false;
            dodgeState.extendedDodgeDirectionLock = false;
            dodgeState.stopMovementRequested = true;
            stopMovement();
            dodgeState.forceMovementBlock = false;
        }
    }

    function triggerDodge(targetX, targetY) {
        dodgeState.stopMovementRequested = true;
        stopMovement();
        
        if (dodgeState.forceMovementBlock && !dodgeState.isDodging && !dodgeState.extendedDodgeActive) {
            if (dodgeState.postDodgeBlockTimer) {
                clearTimeout(dodgeState.postDodgeBlockTimer);
                dodgeState.postDodgeBlockTimer = null;
            }
            dodgeState.forceMovementBlock = false;
        }
        
        if (dodgeState.isDodging || dodgeState.forceMovementBlock) return;
        
        if (dodgeState.dodgeTimeout) clearTimeout(dodgeState.dodgeTimeout);
        if (dodgeState.postDodgeBlockTimer) clearTimeout(dodgeState.postDodgeBlockTimer);
        if (dodgeState.extendedDodgeTimer) clearTimeout(dodgeState.extendedDodgeTimer);
        
        dodgeState.isDodging = true;
        dodgeState.forceMovementBlock = true;
        dodgeState.extendedDodgeActive = false;
        dodgeState.extendedDodgeDirectionLock = false;
        dodgeState.stopMovementRequested = false;
        dodgeState.lastDodgeTime = Date.now();
        dodgeState.currentDodge.x = targetX;
        dodgeState.currentDodge.y = targetY;
        
        moveTo(targetX, targetY);
        
        dodgeState.dodgeTimeout = setTimeout(() => {
            dodgeState.isDodging = false;
            checkExtendedDodge();
            if (!dodgeState.extendedDodgeActive) {
                dodgeState.stopMovementRequested = true;
                stopMovement();
                dodgeState.postDodgeBlockTimer = setTimeout(() => {
                    dodgeState.forceMovementBlock = false;
                }, dodgeConfig.POST_DODGE_BLOCK);
                activeTimeouts.push(dodgeState.postDodgeBlockTimer);
            }
        }, dodgeConfig.DODGE_DURATION);
        activeTimeouts.push(dodgeState.dodgeTimeout);
    }

    const battleUpdateHook = Interceptor.attach(libgBase.add(Offsets.LogicBattleModeClient_update), {
        onEnter(args) {
            try {
                const client = args[0];
                globalBattleModeClient = client;
                if (!client || client.isNull()) return;
                
                dodgeState.ownCharacter = GameMethods.LogicBattleModeClient_getOwnCharacter(client);
                dodgeState.ownTeamId = GameMethods.LogicBattleModeClient_getOwnPlayerTeam(client);
                
                if (!dodgeState.ownCharacter || dodgeState.ownCharacter.isNull() || dodgeState.ownTeamId === -1) return;
                if (!dodgeState.active) return;
                
                const px = GameMethods.LogicGameObjectClient_getX(dodgeState.ownCharacter);
                const py = GameMethods.LogicGameObjectClient_getY(dodgeState.ownCharacter);
                const now = Date.now();
                updatePlayerVelocity(px, py, now);
                
                if (dodgeState.extendedDodgeActive || dodgeState.isDodging) return;
                
                const data = GameMethods.LogicGameObjectClient_getData(dodgeState.ownCharacter);
                const pradius = data ? GameMethods.LogicCharacterData_getCollisionRadius(data) : 0;
                
                const dangerous = getDangerousProjectiles();
                const cooldownOk = (now - dodgeState.lastDodgeTime) > (dodgeConfig.DODGE_COOLDOWN * 1000);
                
                if (dangerous.length > 0 && cooldownOk) {
                    const best = calculateBestDodge(dangerous, px, py, dodgeState.playerVelocity.vx, dodgeState.playerVelocity.vy, pradius, false);
                    if (best) triggerDodge(best.x, best.y);
                }
            } catch (e) {}
        }
    });
    activeHooks.push(battleUpdateHook);

    const Predictor = {
        history: [], vx: 0, vy: 0, smoothing: 0.7, maxHistory: 5,
        update(x, y) {
            const now = Date.now();
            this.history.push({x, y, time: now});
            while (this.history.length > this.maxHistory) this.history.shift();
            
            if (this.history.length >= 2) {
                const prev = this.history[this.history.length - 2];
                const curr = this.history[this.history.length - 1];
                const dt = (curr.time - prev.time) / 1000;
                if (dt > 0.01) {
                    const dx = (curr.x - prev.x) / dt;
                    const dy = (curr.y - prev.y) / dt;
                    this.vx = this.vx * this.smoothing + dx * (1 - this.smoothing);
                    this.vy = this.vy * this.smoothing + dy * (1 - this.smoothing);
                }
            }
        },
        predict(flightTime) {
            if (this.history.length < 2) return {x: targetX, y: targetY};
            const speed = Math.hypot(this.vx, this.vy);
            const last = this.history[this.history.length - 1];
            if (speed < 30) return {x: last.x, y: last.y};
            const maxT = Math.min(flightTime, 0.6);
            return {x: last.x + this.vx * maxT, y: last.y + this.vy * maxT};
        },
        reset() {
            this.history = []; this.vx = 0; this.vy = 0;
        }
    };

    function findClosestTarget() {
        try {
            if (!globalBattleModeClient || globalBattleModeClient.isNull()) {
                Predictor.reset(); isTargetFound = false; return;
            }
            const ownChar = GameMethods.LogicBattleModeClient_getOwnCharacter(globalBattleModeClient);
            if (!ownChar || ownChar.isNull()) {
                Predictor.reset(); isTargetFound = false; return;
            }
            const px = GameMethods.LogicGameObjectClient_getX(ownChar);
            const py = GameMethods.LogicGameObjectClient_getY(ownChar);
            const teamId = GameMethods.LogicBattleModeClient_getOwnPlayerTeam(globalBattleModeClient);
            
            const manager = globalBattleModeClient.add(40).readPointer();
            if (!manager || manager.isNull()) { isTargetFound = false; return; }
            const objCount = manager.add(12).readU32();
            if (objCount === 0 || objCount > 2000) { isTargetFound = false; return; }
            const objArray = manager.readPointer();
            if (!objArray || objArray.isNull()) { isTargetFound = false; return; }
            
            let minDist = Infinity;
            let found = false;
            let bestX = 0, bestY = 0;
            
            for (let i = 0; i < objCount; i++) {
                try {
                    const obj = objArray.add(i * 8).readPointer();
                    if (!obj || obj.isNull()) continue;
                    
                    const data = GameMethods.LogicGameObjectClient_getData(obj);
                    if (!data || data.isNull()) continue;
                    const vtable = data.readPointer();
                    if (vtable && vtable.equals(libgBase.add(Offsets.VTABLE_PROJECTILE_DATA))) continue;
                    
                    const eTeam = obj.add(64).readU32();
                    if (eTeam === teamId || eTeam === 0) continue;
                    
                    const isDead = obj.add(208).readU32();
                    if (isDead !== 0) continue;
                    
                    const ex = GameMethods.LogicGameObjectClient_getX(obj);
                    const ey = GameMethods.LogicGameObjectClient_getY(obj);
                    const sqDist = (ex - px) * (ex - px) + (ey - py) * (ey - py);
                    
                    if (sqDist < minDist) {
                        minDist = sqDist;
                        bestX = ex;
                        bestY = ey;
                        found = true;
                    }
                } catch (e) { continue; }
            }
            
            if (found) {
                targetX = bestX;
                targetY = bestY;
                isTargetFound = true;
                Predictor.update(targetX, targetY);
                return true;
            } else {
                isTargetFound = false;
                Predictor.reset();
                return false;
            }
        } catch (e) {
            isTargetFound = false;
            Predictor.reset();
            return false;
        }
    }

    aimbotInterval = setInterval(() => {
        if (aimbotEnabled) findClosestTarget();
    }, 10);
    activeIntervals.push(aimbotInterval);

    const aimSkillHook = Interceptor.attach(libgBase.add(Offsets.BattleScreen_activateSkill), {
        onEnter(args) {
            if (!aimbotEnabled || !isTargetFound || !globalBattleModeClient || globalBattleModeClient.isNull()) return;
            const skillType = parseInt(args[6]);
            if (skillType !== 0) return;
            
            const ownChar = GameMethods.LogicBattleModeClient_getOwnCharacter(globalBattleModeClient);
            if (!ownChar || ownChar.isNull()) return;
            
            findClosestTarget();
            if (!isTargetFound) return;
            
            const px = GameMethods.LogicGameObjectClient_getX(ownChar);
            const py = GameMethods.LogicGameObjectClient_getY(ownChar);
            const dist = Math.hypot(targetX - px, targetY - py);
            const projSpeed = 3255;
            const flightTime = dist / projSpeed;
            const predicted = Predictor.predict(flightTime);
            
            args[1] = ptr(Math.round(predicted.x));
            args[2] = ptr(Math.round(predicted.y));
        }
    });
    activeHooks.push(aimSkillHook);

    function createButton(text, x, y, callback, styleIndex = 2) {
        try {
            const btnObj = Memory.alloc(528);
            const scPtr = StringManager.createPtr("sc/ui.sc");
            const btnNamePtr = StringManager.createPtr("map_editor_exit_button");
            const movieClip = NativeFuncs.StringTable_getMovieClip(scPtr, btnNamePtr);
            
            if (!movieClip || movieClip.isNull()) {
                libcFree(scPtr); libcFree(btnNamePtr); return null;
            }
            
            NativeFuncs.GameButtonCtor(btnObj);
            new NativeFunction(btnObj.readPointer().add(360).readPointer(), "void", ["pointer", "pointer", "bool"])(btnObj, movieClip, 1);
            
            const txtObj = StringManager.createObject(text);
            NativeFuncs.TextField_setText(btnObj, txtObj, 1);
            
            const tfNamePtr = StringManager.createPtr("Text");
            const textField = NativeFuncs.MovieClip_getTextFieldByName(movieClip, tfNamePtr);
            libcFree(tfNamePtr);
            
            if (textField && !textField.isNull()) {
                NativeFuncs.MovieClipHelper_setTextAndScale(textField, txtObj, 0, 0);
            }
            
            NativeFuncs.MovieClip_gotoAndStopFrameIndex(movieClip, styleIndex);
            NativeFuncs.DisplayObject_setXY(btnObj, x, y);
            NativeFuncs.Stage_addChild(StageInstancePtr, btnObj);
            
            const clickHook = Interceptor.attach(libgBase.add(Offsets.ButtonClickHook), {
                onEnter(args) {
                    if (btnObj.toInt32() === args[0].toInt32()) callback();
                }
            });
            activeHooks.push(clickHook);
            
            libcFree(scPtr); libcFree(btnNamePtr); libcFree(txtObj);
            return {button: btnObj, textObj: txtObj, movieClip: movieClip, originalX: x, originalY: y};
        } catch (e) { return null; }
    }

    function toggleMenu() {
        isMenuOpen = !isMenuOpen;
        const stateText = isMenuOpen ? "HIDE" : "MENU";
        if (menuMainBtn && menuMainBtn.button && !menuMainBtn.button.isNull()) {
            NativeFuncs.TextField_setText(menuMainBtn.button, StringManager.createObject(stateText), 1);
        }
        
        for (let btn of menuButtons) {
            if (btn && btn.button && !btn.button.isNull()) {
                if (isMenuOpen) {
                    NativeFuncs.DisplayObject_setXY(btn.button, btn.originalX, btn.originalY);
                } else {
                    NativeFuncs.DisplayObject_setXY(btn.button, -1000, -1000);
                }
            }
        }
        showFloatingText(isMenuOpen ? "Menu opened" : "Menu closed");
    }

    function buildUI() {
        menuMainBtn = createButton("MENU", 60, 100, function () { toggleMenu(); });
        
        unlockBtn = createButton("UNLOCK❌", 60, 200, function () {
            unlockEnabled = !unlockEnabled;
            if (unlockBtn && unlockBtn.button) {
                NativeFuncs.TextField_setText(unlockBtn.button, StringManager.createObject(unlockEnabled ? "UNLOCK✔" : "UNLOCK❌"), 1);
            }
            showFloatingText(unlockEnabled ? "t.me/BRFMod✔" : "t.me/BRFMod❌");
        });
        if (unlockBtn) menuButtons.push(unlockBtn);
        
        aimbotBtn = createButton("AIMBOT✔", 60, 250, function () {
            aimbotEnabled = !aimbotEnabled;
            if (aimbotBtn && aimbotBtn.button) {
                NativeFuncs.TextField_setText(aimbotBtn.button, StringManager.createObject(aimbotEnabled ? "AIMBOT✔" : "AIMBOT❌"), 1);
            }
            showFloatingText(aimbotEnabled ? "t.me/BRFMod✔" : "t.me/BRFMod❌");
            if (!aimbotEnabled) { isTargetFound = false; targetX = 0; targetY = 0; Predictor.reset(); }
        });
        if (aimbotBtn) menuButtons.push(aimbotBtn);
        
        dodgeBtn = createButton("DODGE✔", 60, 300, function () {
            dodgeState.active = !dodgeState.active;
            if (dodgeBtn && dodgeBtn.button) {
                NativeFuncs.TextField_setText(dodgeBtn.button, StringManager.createObject(dodgeState.active ? "DODGE✔" : "DODGE❌"), 1);
            }
            showFloatingText(dodgeState.active ? "t.me/BRFMod✔" : "t.me/BRFMod❌");
        });
        if (dodgeBtn) menuButtons.push(dodgeBtn);
        
        autoLootBtn = createButton("AUTO LOOT❌", 60, 350, function () {
            showFloatingText("En cours de développement");
        });
        if (autoLootBtn) menuButtons.push(autoLootBtn);
        
        for (let btn of menuButtons) {
            if (btn && btn.button && !btn.button.isNull()) NativeFuncs.DisplayObject_setXY(btn.button, -1000, -1000);
        }
    }

    setTimeout(() => {
        buildUI();
        showFloatingText("Bienvenue sur le Mod par t.me/BRFMod");
    }, 1000);
}

(function () {
    function waitForLibrary(libName, callback) {
        const intervalId = setInterval(function () {
            try {
                const baseAddr = Module.findBaseAddress(libName);
                if (baseAddr) {
                    clearInterval(intervalId);
                    setTimeout(function () { callback(baseAddr); }, 1000);
                }
            } catch (e) {}
        }, 50);
    }

    waitForLibrary("libg.so", function (baseAddress) {
        try {
            initializeMod();
        } catch (e) {}
    });
}());
