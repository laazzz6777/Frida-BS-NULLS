        if (stillInDanger) {
            if (!dodgeState.extendedDodgeActive) {
                dodgeState.extendedDodgeActive = true;
                dodgeState.forceMovementBlock = true;
                dodgeState.extendedDodgeDirectionLock = false;
            }
            
            const bestDodge = calculateBestDodge(dangerous, px, py, dodgeState.playerVelocity.vx, dodgeState.playerVelocity.vy, pradius, true);
            if (bestDodge) {
                let acceptNewAngle = true;
                if (dodgeState.extendedDodgeDirectionLock && dodgeState.lastExtendedDodgeTarget.x !== 0) {
                    const lockAngle = Math.atan2(dodgeState.lastExtendedDodgeTarget.y - py, dodgeState.lastExtendedDodgeTarget.x - px);
