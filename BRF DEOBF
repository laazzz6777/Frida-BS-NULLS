    function evalDodgeSafety(testAngle, dangerousProjs, px, py, pvx, pvy, dodgeDist) {
        const destX = px + Math.cos(testAngle) * dodgeDist;
        const destY = py + Math.sin(testAngle) * dodgeDist;
        let minSqDist = Infinity;
        const dodgeDurSec = dodgeConfig.DODGE_DURATION / 1000;
        
        for (let i = 0; i < dangerousProjs.length; i++) {
            const p = dangerousProjs[i];
            const pxAtT = p.x + Math.cos(p.angle) * p.speed * (p.ttc + dodgeDurSec);
            const pyAtT = p.y + Math.sin(p.angle) * p.speed * (p.ttc + dodgeDurSec);
            const dx = destX - pxAtT;
            const dy = destY - pyAtT;
            const sqDist = dx * dx + dy * dy;
            if (sqDist < minSqDist) minSqDist = sqDist;
        }
        return Math.sqrt(minSqDist);
    }

    function calculateBestDodge(dangerousProjs, px, py, pvx, pvy, pradius, isExtended = false) {
        if (dangerousProjs.length === 0) return null;
        dangerousProjs.sort((a, b) => a.ttc - b.ttc);
        const threat = dangerousProjs[0];
        
        const playerSpeed = Math.hypot(pvx, pvy);
        let dodgeDist = dodgeConfig.DODGE_DISTANCE_BASE;
        
        if (playerSpeed > 10) {
            const moveAngle = Math.atan2(pvy, pvx);
            const threatToPlayerAngle = Math.atan2(threat.y - py, threat.x - px);
            let diff = Math.abs((moveAngle - threatToPlayerAngle + Math.PI) % (2 * Math.PI) - Math.PI);
            if (diff < Math.PI / 3) {
                dodgeDist += Math.min(dodgeConfig.MAX_EXTRA_DISTANCE, playerSpeed * dodgeConfig.EXTRA_DISTANCE_FACTOR);
            }
        }
        
        const angle1 = threat.angle + Math.PI / 2;
        const angle2 = threat.angle - Math.PI / 2;
        const safety1 = evalDodgeSafety(angle1, dangerousProjs, px, py, pvx, pvy, dodgeDist);
        const safety2 = evalDodgeSafety(angle2, dangerousProjs, px, py, pvx, pvy, dodgeDist);
        
        let bestAngle = null;
        let maxSafety = -Infinity;
        
        if (safety1 >= dodgeConfig.STRICT_PERPENDICULAR_SAFETY || safety2 >= dodgeConfig.STRICT_PERPENDICULAR_SAFETY) {
            bestAngle = safety1 >= safety2 ? angle1 : angle2;
            maxSafety = Math.max(safety1, safety2);
        } else {
            const sweepLimit = isExtended ? dodgeConfig.EXTENDED_DODGE_MAX_ANGLE_OFFSET : Math.PI / 12;
            const step = Math.PI / 24;
            
            for (let a = -sweepLimit; a <= sweepLimit; a += step) {
                let test1 = angle1 + a;
                let test2 = angle2 + a;
                let s1 = evalDodgeSafety(test1, dangerousProjs, px, py, pvx, pvy, dodgeDist);
                if (s1 > maxSafety) { maxSafety = s1; bestAngle = test1; }
                let s2 = evalDodgeSafety(test2, dangerousProjs, px, py, pvx, pvy, dodgeDist);
                if (s2 > maxSafety) { maxSafety = s2; bestAngle = test2; }
            }
            
            if (maxSafety < dodgeConfig.DODGE_SAFETY_MARGIN) {
                let avgX = 0, avgY = 0;
                for (let i = 0; i < dangerousProjs.length; i++) {
                    avgX += dangerousProjs[i].x;
                    avgY += dangerousProjs[i].y;
                }
                const awayAngle = Math.atan2(py - avgY / dangerousProjs.length, px - avgX / dangerousProjs.length);
                const sAway = evalDodgeSafety(awayAngle, dangerousProjs, px, py, pvx, pvy, dodgeDist);
                if (sAway > maxSafety) { maxSafety = sAway; bestAngle = awayAngle; }
            }
        }
        
        if (bestAngle === null) return null;
        return {
            x: px + Math.cos(bestAngle) * dodgeDist, 
            y: py + Math.sin(bestAngle) * dodgeDist, 
            angle: bestAngle, 
            distance: dodgeDist, 
            safety: maxSafety
        };
    }

