// ─── Bullet/projectile physics ────────────────────────────────────────────────

/**
 * Calculate time-to-hit for a bullet sweeping toward a point.
 * Returns seconds until impact, or Infinity if no intersection.
 */
function calcBulletTimeToHit(bullet, targetX, targetY, velX, velY, teamRadius) {
    const dx = Math.cos(bullet.angle) * bullet.speed - velX;
    const dy = Math.sin(bullet.angle) * bullet.speed - velY;
    const rx = bullet.startX - targetX;
    const ry = bullet.startY - targetY;
    const a  = dx * dx + dy * dy;
    const b  = 2 * (rx * dx + ry * dy);
    const r  = bullet.radius + teamRadius + cfg.EXTRA_RADIUS;
    const c  = rx * rx + ry * ry - r * r;

    if (c < 0) return 0;
    if (a < 0.0001) {
        if (Math.abs(b) < 0.0001) return Infinity;
        const t0 = -c / b;
        return t0 >= 0 ? t0 : Infinity;
    }
    const discriminant = b * b - 4 * a * c;
    if (discriminant < 0) return Infinity;
    const sqrtD = Math.sqrt(discriminant);
    const t1 = (-b - sqrtD) / (2 * a);
    if (t1 >= 0) return t1;
    const t2 = (-b + sqrtD) / (2 * a);
    return t2 >= 0 ? t2 : Infinity;
}

/**
 * Calculate the closest approach distance between a bullet trajectory
 * and a moving point (used to assess dodge quality).
 */
function calcClosestApproach(bullet, targetX, targetY, velX, velY) {
    const dx = Math.cos(bullet.angle) * bullet.speed - velX;
    const dy = Math.sin(bullet.angle) * bullet.speed - velY;
    const rx = bullet.startX - targetX;
    const ry = bullet.startY - targetY;
    const a  = dx * dx + dy * dy;

    if (a < 0.0001) return { t: 0, dist: Math.hypot(rx, ry) };

    const t  = Math.max(0, -(rx * dx + ry * dy) / a);
    const cx = bullet.startX + Math.cos(bullet.angle) * bullet.speed * t;
    const cy = bullet.startY + Math.sin(bullet.angle) * bullet.speed * t;
    const fx = targetX + velX * t;
    const fy = targetY + velY * t;
    return { t, dist: Math.hypot(cx - fx, cy - fy) };
}

// ─── Aim velocity tracker ─────────────────────────────────────────────────────
function updateAimVelocity(x, y, timestamp) {
    if (dodgeState.prevAimTime > 0) {
        const dt = (timestamp - dodgeState.prevAimTime) / 1000;
        if (dt > 0.01) {
            const dvx   = (x - dodgeState.prevAimPos.x) / dt;
            const dvy   = (y - dodgeState.prevAimPos.y) / dt;
            const alpha = 1 - cfg.VELOCITY_ALPHA;
            dodgeState.velocity.vx = alpha * dvx + cfg.VELOCITY_ALPHA * dodgeState.velocity.vx;
            dodgeState.velocity.vy = alpha * dvy + cfg.VELOCITY_ALPHA * dodgeState.velocity.vy;
        }
    } else {
        dodgeState.velocity.vx = 0;
        dodgeState.velocity.vy = 0;
    }
    dodgeState.prevAimPos.x  = x;
    dodgeState.prevAimPos.y  = y;
    dodgeState.prevAimTime   = timestamp;
}

// ─── Threat scanning ──────────────────────────────────────────────────────────
/**
 * Walk the entity list and return all active bullet/projectile threats
 * that could hit the local player.
 */
function getNearbyThreats() {
    if (!localPlayer || localPlayer.isNull()) return [];

    const entityArray = localPlayer.add(40).readPointer();
    if (!entityArray || entityArray.isNull()) return [];

    const count = entityArray.add(12).readU32();
    if (count === 0 || count > 2000) return [];

    const basePtr = entityArray.readPointer();
    if (!basePtr || basePtr.isNull()) return [];

    const now        = Date.now();
    const threats    = [];
    const seenIds    = new Set();

    let targetX = 0, targetY = 0, targetTeam = 0;
    const hasTarget = dodgeState.targetPtr && !dodgeState.targetPtr.isNull();
    if (hasTarget) {
        targetX    = gameApi.getPosX(dodgeState.targetPtr);
        targetY    = gameApi.getPosY(dodgeState.targetPtr);
        const comp = gameApi.getComponent(dodgeState.targetPtr);
        targetTeam = comp ? gameApi.getEntityTeam(comp) : 0;
    }

    for (let i = 0; i < count; i++) {
        const entity = basePtr.add(i * 8).readPointer();
        if (!entity || entity.isNull()) continue;

        const comp = gameApi.getComponent(entity);
        if (!comp || comp.isNull()) continue;

        // Skip entities whose vtable matches the entity-list marker (i.e. non-bullets)
        const vtable = comp.readPointer();
        if (!vtable.equals(gameBase.add(offsets.ENTITY_LIST_PTR_OFF))) continue;

        const entityId  = gameApi.getEntityHp(entity);
        seenIds.add(entityId);

        const teamId    = entity.add(64).readU32();
        const stateFlag = entity.add(208).readU32();

        if (teamId === dodgeState.targetId || stateFlag !== 0) {
            dodgeState.touchMap.delete(entityId);
            dodgeState.prevTouchMap.delete(entityId);
            continue;
        }

        const posX    = gameApi.getPosX(entity);
        const posY    = gameApi.getPosY(entity);
        const type    = gameApi.getEntityType(comp);
        const subtype = gameApi.getEntitySubtype(comp);

        // Get or create tracking entry for this projectile
        let tracking = dodgeState.prevTouchMap.get(entityId);
        if (!tracking) {
            tracking = { history: [], angle: undefined, speed: type };
            dodgeState.prevTouchMap.set(entityId, tracking);
        }

        tracking.history.push({ x: posX, y: posY, ts: now });
        if (tracking.history.length > cfg.MIN_VELOCITY_PTS) tracking.history.shift();

        // Estimate bullet angle and speed from trajectory history
        let estimatedAngle = tracking.angle;
        let angleKnown     = tracking.angle !== undefined;

        if (tracking.history.length >= 2) {
            const oldest   = tracking.history[0];
            const newest   = tracking.history[tracking.history.length - 1];
            const dxTotal  = newest.x - oldest.x;
            const dyTotal  = newest.y - oldest.y;
            const distTrav = Math.hypot(dxTotal, dyTotal);
            const dtTotal  = (newest.ts - oldest.ts) / 1000;

            if (distTrav > cfg.MIN_CANDIDATES && dtTotal > 0) {
                estimatedAngle = Math.atan2(dyTotal, dxTotal);
                angleKnown     = true;
                tracking.angle = estimatedAngle;
                const estimatedSpeed = distTrav / dtTotal;
                if (estimatedSpeed > cfg.MAX_TARGETS) tracking.speed = estimatedSpeed;
            }
        }

        const bulletSpeed = tracking.speed || type;
        const bullet = {
            startX: posX,
            startY: posY,
            speed:  bulletSpeed,
            radius: subtype,
            angle:  estimatedAngle,
        };
        dodgeState.touchMap.set(entityId, { ...bullet, ts: now });

        // If this bullet is angled and fast enough, check if it's a threat
        if (angleKnown && bulletSpeed > cfg.MAX_TARGETS && hasTarget) {
            const approach = calcClosestApproach(bullet, targetX, targetY,
                                                  dodgeState.velocity.vx, dodgeState.velocity.vy);
            const threshold = subtype + targetTeam + cfg.EXTRA_RADIUS;

            if (approach.dist < threshold) {
                const timeToHit = calcBulletTimeToHit(bullet, targetX, targetY,
                                                       dodgeState.velocity.vx, dodgeState.velocity.vy, targetTeam);
                if (timeToHit < cfg.HIT_RADIUS) {
                    threats.push({ ...bullet, t: timeToHit, bulletDist: approach.dist, id: entityId });
                }
            }
        }
    }

    // Purge stale bullets from the tracking maps
    for (const [id, entry] of dodgeState.touchMap) {
        if (!seenIds.has(id) || now - entry.ts > cfg.MAX_AIM_DIST) {
            dodgeState.touchMap.delete(id);
            dodgeState.prevTouchMap.delete(id);
        }
    }

    return threats;
}

// ─── Dodge direction evaluation ───────────────────────────────────────────────
/**
 * Score how safe a given dodge angle is — higher = safer.
 * Returns the minimum distance to any incoming bullet trajectory.
 */
function evalDodgeAngle(angle, threats, playerX, playerY, velX, velY, teamRadius, predictMs) {
    const endX = playerX + Math.cos(angle) * predictMs;
    const endY = playerY + Math.sin(angle) * predictMs;
    const dt   = cfg.SCREEN_HEIGHT / 1000;
    let minDistSq = Infinity;

    for (let i = 0; i < threats.length; i++) {
        const b  = threats[i];
        const bx = b.startX + Math.cos(b.angle) * b.speed * (b.t + dt);
        const by = b.startY + Math.sin(b.angle) * b.speed * (b.t + dt);
        const dx = endX - bx;
        const dy = endY - by;
        const distSq = dx * dx + dy * dy;
        if (distSq < minDistSq) minDistSq = distSq;
    }
    return Math.sqrt(minDistSq);
}

/**
 * Find the best dodge direction given the current set of threats.
 * Returns { x, y, angle, dist, closestDist } or null.
 */
function findBestDodgeDir(threats, playerX, playerY, velX, velY, teamRadius, isUrgent) {
    if (threats.length === 0) return null;

    threats.sort((a, b) => a.t - b.t);
    const nearestThreat = threats[0];
    const speed = Math.hypot(velX, velY);
    let predictMs = cfg.SCREEN_WIDTH;

    if (speed > 10) {
        const playerAngle = Math.atan2(velY, velX);
        const threatAngle = Math.atan2(nearestThreat.startY - playerY,
                                        nearestThreat.startX - playerX);
        let angleDiff = Math.abs((playerAngle - threatAngle + Math.PI) % (2 * Math.PI) - Math.PI);
        if (angleDiff < Math.PI / 3) {
            predictMs += Math.min(cfg.MAX_PREDICT_MS, speed * cfg.PREDICT_SCALE);
        }
    }

    const perpLeft  = nearestThreat.angle + Math.PI / 2;
    const perpRight = nearestThreat.angle - Math.PI / 2;
    const scoreLeft  = evalDodgeAngle(perpLeft,  threats, playerX, playerY, velX, velY, teamRadius, predictMs);
    const scoreRight = evalDodgeAngle(perpRight, threats, playerX, playerY, velX, velY, teamRadius, predictMs);

    let bestAngle = null;
    let bestScore = -Infinity;

    if (scoreLeft >= cfg.LOOT_TICK_RATE || scoreRight >= cfg.LOOT_TICK_RATE) {
        bestAngle = scoreLeft >= scoreRight ? perpLeft : perpRight;
        bestScore = Math.max(scoreLeft, scoreRight);
    } else {
        const sweepRange = isUrgent ? cfg.MAX_AIM_ANGLE : Math.PI / 12;
        const sweepStep  = Math.PI / 24;

        for (let delta = -sweepRange; delta <= sweepRange; delta += sweepStep) {
            const angleA = perpLeft  + delta;
            const angleB = perpRight + delta;
            const scoreA = evalDodgeAngle(angleA, threats, playerX, playerY, velX, velY, teamRadius, predictMs);
            const scoreB = evalDodgeAngle(angleB, threats, playerX, playerY, velX, velY, teamRadius, predictMs);
            if (scoreA > bestScore) { bestScore = scoreA; bestAngle = angleA; }
            if (scoreB > bestScore) { bestScore = scoreB; bestAngle = angleB; }
        }

        // Fallback: aim away from the centroid of all threats
        if (bestScore < cfg.LOOT_INTERVAL) {
            let cx = 0, cy = 0;
            for (const t of threats) { cx += t.startX; cy += t.startY; }
            cx /= threats.length; cy /= threats.length;
            const awayAngle = Math.atan2(playerY - cy, playerX - cx);
            const awayScore = evalDodgeAngle(awayAngle, threats, playerX, playerY, velX, velY, teamRadius, predictMs);
            if (awayScore > bestScore) { bestScore = awayScore; bestAngle = awayAngle; }
        }
    }

    if (bestAngle === null) return null;

    return {
        x:            playerX + Math.cos(bestAngle) * predictMs,
        y:            playerY + Math.sin(bestAngle) * predictMs,
        angle:        bestAngle,
        dist:         predictMs,
        closestDist:  bestScore,
    };
}

// ─── Dodge execution ──────────────────────────────────────────────────────────
function stopDodge() {
    if (dodgeState.lootTimer) {
        clearInterval(dodgeState.lootTimer);
        dodgeState.lootTimer = null;
    }
    dodgeState.killAuraActive = false;
}

/**
 * Send a touch event to steer the player toward (moveX, moveY).
 */
function sendTouchEvent(moveX, moveY) {
    try {
        if (!localPlayer || localPlayer.isNull()) return false;
        const playerList = gameApi.getPlayerList();
        if (!playerList || playerList.isNull()) return false;
        const listBase = playerList.add(88).readPointer();
        if (!listBase || listBase.isNull()) return false;
        const eventBuf = malloc(96);
        if (!eventBuf || eventBuf.isNull()) return false;
        gameApi.allocEntity(eventBuf, 2);
        eventBuf.add(12).writeS32(moveX);
        eventBuf.add(16).writeS32(moveY);
        gameApi.setEntityParent(listBase, eventBuf);
        return true;
    } catch (e) {
        return false;
    }
}

/**
 * Start periodically nudging the player toward (destX, destY) to dodge.
 */
function startDodgeMove(destX, destY) {
    stopDodge();
    // Only push if we have drifted far enough from the target
    if (localPlayer && dodgeState.targetPtr && !dodgeState.targetPtr.isNull()) {
        const tx = gameApi.getPosX(dodgeState.targetPtr);
        const ty = gameApi.getPosY(dodgeState.targetPtr);
        if ((tx - destX) ** 2 + (ty - destY) ** 2 > 25)
            sendTouchEvent(destX, destY);
    }
    dodgeState.lootTimer = setInterval(() => {
        if (dodgeState.isDodging || dodgeState.isInactive)
            sendTouchEvent(destX, destY);
        else
            stopDodge();
    }, cfg.LOOT_TYPE);
    activeIntervals.push(dodgeState.lootTimer);
}

/**
 * Re-evaluate the threat list and decide if/where to dodge.
 */
function runDodgeLogic() {
    if (!dodgeState.isDodging && !dodgeState.isInactive) return;

    const tx   = gameApi.getPosX(dodgeState.targetPtr);
    const ty   = gameApi.getPosY(dodgeState.targetPtr);
    const comp = gameApi.getComponent(dodgeState.targetPtr);
    const team = comp ? gameApi.getEntityTeam(comp) : 0;

    const threats = getNearbyThreats();

    if (threats.length === 0) {
        if (dodgeState.isInactive) {
            dodgeState.isInactive     = false;
            dodgeState.hasLootTarget  = false;
            dodgeState.killAuraActive = true;
            stopDodge();
            dodgeState.dodgeReady = false;
        }
        return;
    }

    // Check if any bullet will hit us
    let incoming = false;
    for (let i = 0; i < threats.length; i++) {
        const tth = calcBulletTimeToHit(threats[i], tx, ty,
                                         dodgeState.velocity.vx, dodgeState.velocity.vy, team);
        if (tth < 0.8) { incoming = true; break; }
    }

    if (incoming) {
        if (!dodgeState.isInactive) {
            dodgeState.isInactive    = true;
            dodgeState.dodgeReady    = true;
            dodgeState.hasLootTarget = false;
        }
        const best = findBestDodgeDir(threats, tx, ty,
                                       dodgeState.velocity.vx, dodgeState.velocity.vy, team, true);
        if (best) {
            let useDir = true;
            if (dodgeState.hasLootTarget && dodgeState.lootPos.x !== 0) {
                const awayAngle   = Math.atan2(dodgeState.lootPos.y - ty, dodgeState.lootPos.x - tx);
                const awayScore   = evalDodgeAngle(awayAngle, threats, tx, ty,
                                                    dodgeState.velocity.vx, dodgeState.velocity.vy,
                                                    team, cfg.SCREEN_WIDTH);
                if (best.closestDist < awayScore + cfg.KILLAURA_RADIUS) useDir = false;
            }
            if (useDir) {
                dodgeState.lootPos.x    = best.x;
                dodgeState.lootPos.y    = best.y;
                dodgeState.hasLootTarget = true;
                startDodgeMove(best.x, best.y);
            }
        }
        if (dodgeState.killAuraTimer) clearTimeout(dodgeState.killAuraTimer);
        dodgeState.killAuraTimer = setTimeout(runDodgeLogic, cfg.TEAM_FILTER);
        activeTimeouts.push(dodgeState.killAuraTimer);
    } else {
        dodgeState.isInactive     = false;
        dodgeState.hasLootTarget  = false;
        dodgeState.killAuraActive = true;
        stopDodge();
        dodgeState.dodgeReady = false;
    }
}

/**
 * Called when a new threat is detected at (threatX, threatY).
 * Arms the dodge system.
 */
function onThreatDetected(threatX, threatY) {
    dodgeState.killAuraActive = true;
    stopDodge();

    if (dodgeState.dodgeReady && !dodgeState.isDodging && !dodgeState.isInactive) {
        if (dodgeState.dodgeTimer) { clearTimeout(dodgeState.dodgeTimer); dodgeState.dodgeTimer = null; }
        dodgeState.dodgeReady = false;
    }

    if (dodgeState.isDodging || dodgeState.dodgeReady) return;

    if (dodgeState.prevPos)     clearTimeout(dodgeState.prevPos);
    if (dodgeState.dodgeTimer)  clearTimeout(dodgeState.dodgeTimer);
    if (dodgeState.killAuraTimer) clearTimeout(dodgeState.killAuraTimer);

    dodgeState.isDodging      = true;
    dodgeState.dodgeReady     = true;
    dodgeState.isInactive     = false;
    dodgeState.hasLootTarget  = false;
    dodgeState.killAuraActive = false;
    dodgeState.lastUpdateTime = Date.now();
    dodgeState.aimPos.x       = threatX;
    dodgeState.aimPos.y       = threatY;

    startDodgeMove(threatX, threatY);

    dodgeState.prevPos = setTimeout(() => {
        dodgeState.isDodging = false;
        runDodgeLogic();
        if (!dodgeState.isInactive) {
            dodgeState.killAuraActive = true;
            stopDodge();
            dodgeState.dodgeTimer = setTimeout(() => {
                dodgeState.dodgeReady = false;
            }, cfg.DODGE_INTERVAL);
            activeTimeouts.push(dodgeState.dodgeTimer);
        }
    }, cfg.SCREEN_HEIGHT);
    activeTimeouts.push(dodgeState.prevPos);
}

// ─── Aimbot: enemy scanner ────────────────────────────────────────────────────
/**
 * Scan entities and lock onto the nearest living enemy.
 * Updates aimTargetX/Y and aimbotActive.
 */
function findNearestEnemy() {
    try {
        if (!localPlayer || localPlayer.isNull())
            return velocityTracker.reset(), aimbotActive = false;

        const selfObj = gameApi.getEntityObj(localPlayer);
        if (!selfObj || selfObj.isNull())
            return velocityTracker.reset(), aimbotActive = false;

        const selfX    = gameApi.getPosX(selfObj);
        const selfY    = gameApi.getPosY(selfObj);
        const selfTeam = gameApi.isEntityAlive(localPlayer);  // used as team ID field here

        const entityArray = localPlayer.add(40).readPointer();
        if (!entityArray || entityArray.isNull()) return aimbotActive = false;
        const count = entityArray.add(12).readU32();
        if (count === 0 || count > 2000) return aimbotActive = false;
        const basePtr = entityArray.readPointer();
        if (!basePtr || basePtr.isNull()) return aimbotActive = false;

        let nearestDistSq = Infinity;
        let foundEnemy    = false;
        let bestX = 0, bestY = 0;

        for (let i = 0; i < count; i++) {
            try {
                const entity = basePtr.add(i * 8).readPointer();
                if (!entity || entity.isNull()) continue;

                const comp = gameApi.getComponent(entity);
                if (!comp || comp.isNull()) continue;

                // Skip if vtable matches entity list (not a player)
                const vtable = comp.readPointer();
                if (vtable && vtable.equals(gameBase.add(offsets.ENTITY_LIST_PTR_OFF))) continue;

                const teamId    = entity.add(64).readU32();
                const stateFlag = entity.add(208).readU32();

                if (teamId === selfTeam || teamId === 0) continue;
                if (stateFlag !== 0) continue;  // dead / invalid

                const ex = gameApi.getPosX(entity);
                const ey = gameApi.getPosY(entity);
                const distSq = (ex - selfX) ** 2 + (ey - selfY) ** 2;

                if (distSq < nearestDistSq) {
                    nearestDistSq = distSq;
                    bestX = ex;
                    bestY = ey;
                    foundEnemy = true;
                }
            } catch (e) { continue; }
        }

        if (foundEnemy) {
            aimTargetX  = bestX;
            aimTargetY  = bestY;
            aimbotActive = true;
            velocityTracker.addSample(aimTargetX, aimTargetY);
            return true;
        } else {
            aimbotActive = false;
            velocityTracker.reset();
            return false;
        }
    } catch (e) {
        aimbotActive = false;
        velocityTracker.reset();
        return false;
    }
}

// ─── UI builder ───────────────────────────────────────────────────────────────
/**
 * Create a game UI button with the given label at (x, y).
 * onClick is called when the button is tapped.
 */
function createButton(label, x, y, onClick, onClickArg = null, btnType = 2) {
    try {
        const nodeBuf   = Memory.alloc(528);
        const uiPathStr = strUtils.allocCString('sc/ui.sc');
        const btnIdStr  = strUtils.allocCString('map_editor_exit_button');
        const uiObj     = findObject(uiPathStr, btnIdStr);

        if (!uiObj || uiObj.isNull()) {
            freePointers([uiPathStr, btnIdStr]);
            return null;
        }

        initComponent(nodeBuf);
        // Call the clone/init vtable slot
        new NativeFunction(
            nodeBuf.readPointer().add(360).readPointer(),
            'void', ['pointer', 'pointer', 'bool']
        )(nodeBuf, uiObj, true);

        const labelPtr = strUtils.allocGameString(label);
        setButtonText(nodeBuf, labelPtr, 1);

        const textKey    = strUtils.allocCString('Text');
        const textChild  = getChildByName(uiObj, textKey);
        free(textKey);
        if (textChild && !textChild.isNull())
            setTextContent(textChild, labelPtr, 0, 0);

        setButtonType(uiObj, btnType);
        setPosition(nodeBuf, x, y);
        addToScene(entityListPtr, nodeBuf);

        const clickInterceptor = Interceptor.attach(gameBase.add(offsets.BTN_CLICK_OFF), {
            onEnter(args) {
                if (nodeBuf.toInt32() === args[0].toInt32()) onClick(onClickArg);
            }
        });
        activeInterceptors.push(clickInterceptor);
        freePointers([uiPathStr, btnIdStr]);

        return { nodePtr: nodeBuf, labelPtr, uiObj, posX: x, posY: y };
    } catch (e) {
        return null;
    }
}

