// ─── Velocity tracker (smooth exponential-moving-average) ─────────────────────
const velocityTracker = {
    samples:    [],
    velX:       0,
    velY:       0,
    smoothing:  0.7,
    maxSamples: 5,

    addSample(x, y) {
        const now = Date.now();
        const sample = { x, y, time: now };
        this.samples.push(sample);
        while (this.samples.length > this.maxSamples) this.samples.shift();

        if (this.samples.length >= 2) {
            const prev    = this.samples[this.samples.length - 2];
            const curr    = this.samples[this.samples.length - 1];
            const dt      = (curr.time - prev.time) / 1000;
            if (dt > 0.01) {
                const dvx = (curr.x - prev.x) / dt;
                const dvy = (curr.y - prev.y) / dt;
                this.velX = this.velX * this.smoothing + dvx * (1 - this.smoothing);
                this.velY = this.velY * this.smoothing + dvy * (1 - this.smoothing);
            }
        }
    },

    predict(dt) {
        if (this.samples.length < 2) return { x: aimTargetX, y: aimTargetY };
        const last = this.samples[this.samples.length - 1];
        const speed = Math.hypot(this.velX, this.velY);
        if (speed < 1) return { x: last.x, y: last.y };
        const t = Math.min(dt, 0.6);
        return { x: last.x + this.velX * t, y: last.y + this.velY * t };
    },

    reset() {
        this.samples = [];
        this.velX = 0;
        this.velY = 0;
    }
};

// ─── Frida utility wrappers ───────────────────────────────────────────────────
function attachInterceptor(address, callbacks) {
    try {
        if (!address || address.isNull()) return null;
        return Interceptor.attach(address, callbacks);
    } catch (e) {
        return null;
    }
}

function safeReplace(address, replacement) {
    try {
        if (!address || address.isNull()) return;
        Interceptor.replace(address, replacement);
    } catch (e) {}
}

function clearAllIntervals() {
    for (const id of activeIntervals) clearInterval(id);
    activeIntervals = [];
}

function clearAllTimeouts() {
    for (const id of activeTimeouts) clearTimeout(id);
    activeTimeouts = [];
}

function cleanupAll() {
    clearAllIntervals();
    clearAllTimeouts();
    for (const interceptor of activeInterceptors) {
        try { interceptor.detach(); } catch (e) {}
    }
    activeInterceptors = [];
}

Script.bindWeak(this, function() {
