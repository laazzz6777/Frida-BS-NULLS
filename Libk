// ─── Main initialisation ──────────────────────────────────────────────────────
function initMod() {
    'use strict';
    cleanupAll();

    gameBase = Module.findBaseAddress('libg.so');
    if (!gameBase) {
        console.log('libg.so not found!');
        return;
    }

    // libc helpers
    malloc = new NativeFunction(Module.getExportByName('libc.so', 'malloc'), 'pointer', ['uint']);
    free   = new NativeFunction(Module.getExportByName('libc.so', 'free'),   'void',    ['pointer']);

    // ── Game function offsets ────────────────────────────────────────────────
    offsets = {
        FIND_ENTITY_OFF:     11659572,
        GET_PLAYER_LIST_OFF:  9463604,
        SET_ENTITY_PARENT_OFF:7677284,
        ALLOC_ENTITY_OFF:    11420908,
        GET_COMPONENT_OFF:   10995228,
        GET_ENTITY_TYPE_OFF: 10617980,
        GET_ENTITY_SUBTYPE_OFF:10618108,
        GET_ENTITY_TEAM_OFF: 10340096,
        GET_POS_X_OFF:       10995948,
        GET_POS_Y_OFF:       10995956,
        GET_POS_Z_OFF:       10995964,
        GET_ENTITY_HP_OFF:   10995864,
        GET_ENTITY_OBJ_OFF:  11666556,
        GET_ENTITY_ALIVE_OFF:11665620,
        ENTITY_LIST_PTR_OFF: 17577720,
        TOUCH_HANDLER_OFF:    8107136,
        ON_TOUCH_EVENT_OFF:   8088720,
        GET_ROOT_NODE_OFF:    5717712,
        CREATE_STRING_OFF:   13968800,
        SET_TOAST_OFF:        5720412,
        ANTI_CHEAT_OFF:      10690108,
        BTN_CLICK_OFF:       12421880,
        ADD_TO_SCENE_OFF:    12319064,
        SET_BTN_TEXT_OFF:     5746332,
        INIT_COMPONENT_OFF:   5744716,
        GET_CHILD_OFF:       12221696,
        SET_TEXT_OFF:         9718956,
        SET_POSITION_OFF:    12198532,
        SET_BTN_TYPE_OFF:    12217964,
        SET_VISIBLE_OFF:     12284116,
        SET_IMAGE_OFF:       12425404,
    };

    // ── Resolve native functions ─────────────────────────────────────────────
    entityListPtr  = gameBase.add(offsets.ENTITY_LIST_PTR_OFF).readPointer();
    // (Note: UNK_C28 was the actual entityListPtr source offset — 18525472)

    findObject     = new NativeFunction(gameBase.add(offsets.ALLOC_ENTITY_OFF /*UNK_C27*/), 'pointer', ['pointer', 'pointer']);
    initComponent  = new NativeFunction(gameBase.add(offsets.INIT_COMPONENT_OFF), 'void',    ['pointer']);
    getChildByName = new NativeFunction(gameBase.add(offsets.GET_CHILD_OFF),       'pointer', ['pointer', 'pointer']);
    setTextContent = new NativeFunction(gameBase.add(offsets.SET_TEXT_OFF),         'void',    ['pointer', 'pointer', 'int', 'int']);
    setButtonType  = new NativeFunction(gameBase.add(offsets.SET_BTN_TYPE_OFF),     'void',    ['pointer', 'int']);
    setPosition    = new NativeFunction(gameBase.add(offsets.SET_POSITION_OFF),     'void',    ['pointer', 'float', 'float']);
    addToScene     = new NativeFunction(gameBase.add(offsets.ADD_TO_SCENE_OFF),     'pointer', ['pointer', 'pointer']);
    setButtonText  = new NativeFunction(gameBase.add(offsets.SET_BTN_TEXT_OFF),     'pointer', ['pointer', 'pointer', 'int']);
    setVisible     = new NativeFunction(gameBase.add(offsets.SET_VISIBLE_OFF),      'void',    ['pointer', 'int']);
    setImage       = new NativeFunction(gameBase.add(offsets.SET_IMAGE_OFF),        'void',    ['pointer', 'pointer', 'pointer']);

    gameApi = {
        getPlayerList:   new NativeFunction(gameBase.add(offsets.GET_PLAYER_LIST_OFF),  'pointer', []),
        allocEntity:     new NativeFunction(gameBase.add(offsets.ALLOC_ENTITY_OFF),     'pointer', ['pointer', 'int']),
        setEntityParent: new NativeFunction(gameBase.add(offsets.SET_ENTITY_PARENT_OFF),'void',    ['pointer', 'pointer']),
        getComponent:    new NativeFunction(gameBase.add(offsets.GET_COMPONENT_OFF),    'pointer', ['pointer']),
        getEntityType:   new NativeFunction(gameBase.add(offsets.GET_ENTITY_TYPE_OFF),  'uint32',  ['pointer']),
        getEntitySubtype:new NativeFunction(gameBase.add(offsets.GET_ENTITY_SUBTYPE_OFF),'uint32', ['pointer']),
        getEntityTeam:   new NativeFunction(gameBase.add(offsets.GET_ENTITY_TEAM_OFF),  'uint32',  ['pointer']),
        getPosX:         new NativeFunction(gameBase.add(offsets.GET_POS_X_OFF),        'uint32',  ['pointer']),
        getPosY:         new NativeFunction(gameBase.add(offsets.GET_POS_Y_OFF),        'uint32',  ['pointer']),
        getEntityHp:     new NativeFunction(gameBase.add(offsets.GET_ENTITY_HP_OFF),    'uint32',  ['pointer']),
        getEntityObj:    new NativeFunction(gameBase.add(offsets.GET_ENTITY_OBJ_OFF),   'pointer', ['pointer']),
        isEntityAlive:   new NativeFunction(gameBase.add(offsets.GET_ENTITY_ALIVE_OFF), 'uint32',  ['pointer']),
        getRootNodeFn:   new NativeFunction(gameBase.add(offsets.GET_ROOT_NODE_OFF),    'pointer', []),
        createStringFn:  new NativeFunction(gameBase.add(offsets.CREATE_STRING_OFF),    'pointer', ['pointer', 'pointer']),
        setToastFn:      new NativeFunction(gameBase.add(offsets.SET_TOAST_OFF),        'void',    ['pointer', 'pointer', 'float', 'int']),
    };

    getRootNode  = gameApi.getRootNodeFn;
    createString = gameApi.createStringFn;
    setToast     = gameApi.setToastFn;

    // ── String utility helpers ───────────────────────────────────────────────
    strUtils = {
        // Allocate a raw C string in game memory (caller must free)
        allocCString(str) {
            const buf = malloc(str.length + 1);
            Memory.writeUtf8String(buf, str);
            return buf;
        },
        // Allocate a game engine String object (caller must free with free())
        allocGameString(str) {
            const cStr    = this.allocCString(str);
            const gameStr = malloc(96);
            createString(gameStr, cStr);
            free(cStr);
            return gameStr;
        },
    };

    showToast = function(message) {
        try {
            const rootNode = getRootNode();
            if (!rootNode || rootNode.isNull()) return;
            const msgPtr = strUtils.allocGameString(message);
            if (!msgPtr || msgPtr.isNull()) return;
            setToast(rootNode, msgPtr, 0, -1);
            free(msgPtr);
        } catch (e) {}
    };

    // ── Anti-cheat bypass (UNLOCK feature) ───────────────────────────────────
    const antiCheatAddr = gameBase.add(offsets.ANTI_CHEAT_OFF);
    origAntiCheatCheck  = new NativeFunction(antiCheatAddr, 'bool', ['int64', 'pointer']);
    Interceptor.replace(antiCheatAddr, new NativeCallback(function(arg0, arg1) {
        if (unlockEnabled) return 1;   // always pass the check
        return origAntiCheatCheck(arg0, arg1);
    }, 'bool', ['int64', 'pointer']));

    // ── AIMBOT — player-update interceptor ───────────────────────────────────
    // Fires every frame for each entity; we use it to track localPlayer
    const playerUpdateInterceptor = attachInterceptor(
        gameBase.add(offsets.FIND_ENTITY_OFF), {
        onEnter(args) {
            try {
                const player = args[0];
                localPlayer = player;
                if (!player || player.isNull()) return;

                dodgeState.targetPtr = gameApi.getEntityObj(player);
                dodgeState.targetId  = gameApi.isEntityAlive(player);

                if (!dodgeState.targetPtr || dodgeState.targetPtr.isNull()
                    || dodgeState.targetId === -1) return;
                if (!dodgeState.dodgeActive) return;

                const px        = gameApi.getPosX(dodgeState.targetPtr);
                const py        = gameApi.getPosY(dodgeState.targetPtr);
                const now       = Date.now();
                updateAimVelocity(px, py, now);

                if (dodgeState.isInactive || dodgeState.isDodging) return;

                const comp    = gameApi.getComponent(dodgeState.targetPtr);
                const team    = comp ? gameApi.getEntityTeam(comp) : 0;
                const threats = getNearbyThreats();
                const stale   = now - dodgeState.lastUpdateTime > cfg.VELOCITY_SMOOTH * 1000;

                if (threats.length > 0 && stale) {
                    const best = findBestDodgeDir(threats, px, py,
                                                   dodgeState.velocity.vx, dodgeState.velocity.vy,
                                                   team, false);
                    if (best) onThreatDetected(best.x, best.y);
                }
            } catch (e) {}
        }
    });
    activeInterceptors.push(playerUpdateInterceptor);

    // ── AIMBOT — polling interval ─────────────────────────────────────────────
    const aimbotInterval = setInterval(() => {
        if (aimbotEnabled) findNearestEnemy();
    }, 10);
    activeIntervals.push(aimbotInterval);

    // ── AIMBOT — touch event interceptor (deflects aim toward predicted pos) ──
    const aimTouchInterceptor = attachInterceptor(
        gameBase.add(offsets.ON_TOUCH_EVENT_OFF), {
        onEnter(args) {
            if (!aimbotEnabled || !aimbotActive || !localPlayer || localPlayer.isNull()) return;
            const touchType = parseInt(args[6]);
            if (touchType !== 0) return;   // only handle tap-down

            const selfObj = gameApi.getEntityObj(localPlayer);
            if (!selfObj || selfObj.isNull()) return;

            findNearestEnemy();
            if (!aimbotActive) return;

            const selfX  = gameApi.getPosX(selfObj);
            const selfY  = gameApi.getPosY(selfObj);
            const dist   = Math.hypot(aimTargetX - selfX, aimTargetY - selfY);
            const tof    = dist / 3255;  // time of flight (bullet speed ~3255 units/s)
            const pred   = velocityTracker.predict(tof);

            args[1] = ptr(Math.round(pred.x));
            args[2] = ptr(Math.round(pred.y));
        }
    });
    activeInterceptors.push(aimTouchInterceptor);

    // ── KILLAURA — replace touch handler to always return "hit" ──────────────
    const touchHandlerAddr = gameBase.add(offsets.TOUCH_HANDLER_OFF);
    Interceptor.replace(touchHandlerAddr, new NativeCallback(function() {
        if (killAuraEnabled && featureFlags.killAuraUnlocked) return 1;
        return 0;
    }, 'bool', []));

    // ── KILLAURA — suppress event cancellation ────────────────────────────────
    const killAuraTouchInterceptor = attachInterceptor(
        gameBase.add(offsets.ON_TOUCH_EVENT_OFF), {
        onEnter(args) {
            if (!killAuraEnabled) return;
            const touchType = parseInt(args[6]);
            if (touchType === 1 && !featureFlags.aimbotUnlocked)
                args[6] = ptr(-1);   // prevent the game from cancelling the hit
        }
    });
    activeInterceptors.push(killAuraTouchInterceptor);

    // ── Build the in-game UI and show the welcome toast ──────────────────────
    setTimeout(() => {
        buildUI();
        showToast('Приветик юзер прекрасного ');
        // "Hello user of the amazing mod "
    }, 1000);
    activeTimeouts.push(setTimeout);
}

// ─── Entry point: wait for libg.so then run ───────────────────────────────────
(function waitForLibg() {
    const pollInterval = setInterval(function() {
        try {
            const base = Module.findBaseAddress('libg.so');
            if (base) {
                clearInterval(pollInterval);
                setTimeout(() => {
                    try { initMod(); } catch (e) {}
                }, 1000);
            }
        } catch (e) {}
    }, 50);
}());
