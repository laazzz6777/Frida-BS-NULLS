runAimbot() internal calls:

FN.activateSkill():
retType: "void"
argTypes: ["pointer", "int", "int", "int", "int", "pointer", "pointer", "int", "int"]
args[0] = battleScreen (pointer)
args[1] = 0 (normal) or 1 (super)
args[2] = aimX | 0 (int)
args[3] = aimY | 0 (int)
args[4] = 0 (int)
args[5] = ptr(0) (pointer)
args[6] = target (pointer)
args[7] = 0 (int)
args[8] = 0 (int)

FN.useAccessory():
retType: "void"
argTypes: ["pointer", "pointer"]
args[0] = State.ownCharPtr (pointer)
args[1] = gadgetData (pointer from offset 0x150)

FN.activateHyperCharge():
retType: "void"
argTypes: ["pointer"]
args[0] = State.ownCharPtr (pointer)

AimSolver.computeAimPoint():
args[0] = srcX (float) - own X
args[1] = srcY (float) - own Y
args[2] = targetPtr (pointer) - enemy character

AimSolver.selectBestTarget():
args[0] = srcX (float) - own X
args[1] = srcY (float) - own Y

solveIntercept():
args[0] = srcX (float)
args[1] = srcY (float)
args[2] = bulletSpeed (float)
args[3] = tarX (float)
args[4] = tarY (float)
args[5] = tarVX (float)
args[6] = tarVY (float)
args[7] = maxIter (int)

getEnemyPrediction(ptr):
args[0] = ptr (pointer) - enemy character
reads: LogicGameObjectClient_getX, LogicGameObjectClient_getY

getEnemyFeatures(ptr, kf):
args[0] = ptr (pointer) - enemy character
args[1] = kf (KalmanFilter2D) - {x, y, vx, vy}
reads: LogicCharacterClient_getHealth, LogicCharacterClient_getMaxHealth

updateEnemyBehaviorLSTM(ptr, features):
args[0] = ptr (pointer) - enemy character
args[1] = features (array of 10 floats)
reads: LogicGameObjectClient_getGlobalID

safeReadPtr(State.battleClient, 8):
offset 8 = battleScreen pointer



