Interceptor.replace(FULL_OFFSETS.LogicBattleModeClient_isWallBetween, new NativeCallback(() => 0, 'int', []));

Interceptor.attach(FULL_OFFSETS.LogicBattleModeClient_setClientPredictionMoveTo, {
    onEnter: function(args) {
        const bm = new NativeFunction(FULL_OFFSETS.BattleMode_getInstance, 'pointer', [])();
        const me = new NativeFunction(FULL_OFFSETS.LogicBattleModeClient_getOwnCharacter, 'pointer', ['pointer'])(bm);
        if (!me.isNull()) {
            const attached = me.add(FULL_OFFSETS.OFF_ATTACHED_ENTITY).readPointer();
            if (!attached.isNull()) {
                me.add(FULL_OFFSETS.OFF_CHARACTER_X).writeS32(args[1].toInt32());
                me.add(FULL_OFFSETS.OFF_CHARACTER_Y).writeS32(args[2].toInt32());
                args[1] = attached.add(FULL_OFFSETS.OFF_CHARACTER_X).readPointer();
                args[2] = attached.add(FULL_OFFSETS.OFF_CHARACTER_Y).readPointer();
            }
        }
    }
});

const detachSites = [0xB1E46C, 0xB1E570, 0xB1E8C4];
