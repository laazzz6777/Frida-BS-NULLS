const FULL_OFFSETS = {
    LogicBattleModeClient_update: base.add(0xBF9514),
    LogicBattleModeClient_getOwnCharacter: base.add(0xB20614),
    LogicBattleModeClient_setClientPredictionMoveTo: base.add(0xB20830),
    LogicInputManager_canSendInput: base.add(0x4B2024),
    LogicCharacterClient_canAttack: base.add(0xB2E300),
    LogicCharacterClient_isAlive: base.add(0xB1FFC8),
    LogicCharacterClient_shouldShowMovementJoystick: base.add(0x620A08),
    LogicCharacterClient_getWeaponRange: base.add(0xB2008C),
    LogicCharacterClient_getAttackAngle: base.add(0xB20094),
    LogicCharacterClient_isKnockedBack: base.add(0xB2009C),
    LogicBattleModeClient_isWallBetween: base.add(0xCC6328),
    BattleMode_getInstance: base.add(0xB53CD4),
    Global_InputManager: base.add(0x11A20E8),
    LogicChecksum_verify: base.add(0x6FAC60),
    OFF_ATTACHED_ENTITY: 0x1C8,
    OFF_CHARACTER_X: 0x38,
