Interceptor.replace(FULL_OFFSETS.LogicInputManager_canSendInput, new NativeCallback(function() {
    const mgr = FULL_OFFSETS.Global_InputManager.readPointer();
    if (mgr.isNull()) return new NativeFunction(base.add(0x9F44A0), 'pointer', [])();
    mgr.add(0xF0).writeU8(0); 
    return mgr;
}, 'pointer', []));

