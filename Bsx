    function sendInput(x, y, isDodge = false) {
        const now = Date.now();
        if (!isDodge && now - dodgeState.lastInput.time < DODGE_CONFIG.INPUT_COOLDOWN) return;
        try {
            const battleMode = natives.BattleMode_getInstance();
            if (!battleMode || battleMode.isNull()) return;
