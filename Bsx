    function predictFuturePosition(timeToPredictSeconds) {
        // Need at least 2 positions and 1 time difference to calculate velocity
        if (latestX.array.length < 2 || timeDiffs.array.length < 1) {
            return { x: latestX.array[latestX.array.length - 1] || 0,
                     y: latestY.array[latestY.array.length - 1] || 0 };
        }
        // Calculate average time difference in seconds
        const totalTimeDiff = timeDiffs.array.reduce((sum, diff) => sum + diff, 0);
        const avgTimeDiff = totalTimeDiff / timeDiffs.array.length / 1000; // convert to seconds
        // Calculate velocities (pixels per second)
        let totalVx = 0;
        let totalVy = 0;
        let weightSum = 0;
      
        // Calculate weighted velocities (more recent movements have higher weight)
        for (let i = 1; i < latestX.array.length; i++) {
            const dx = latestX.array[i] - latestX.array[i - 1];
            const dy = latestY.array[i] - latestY.array[i - 1];
            const dt = timeDiffs.array[i - 1] / 1000; // in seconds
          
            // Skip if time difference is 0 to avoid division by zero
            if (dt <= 0) continue;
          
            const weight = i; // linear weighting (most recent has highest weight)
            totalVx += (dx / dt) * weight;
            totalVy += (dy / dt) * weight;
            weightSum += weight;
        }
        // Calculate weighted average velocity
        const avgVx = weightSum > 0 ? totalVx / weightSum : 0;
        const avgVy = weightSum > 0 ? totalVy / weightSum : 0;
        // Get current position
        const currentX = latestX.array[latestX.array.length - 1];
        const currentY = latestY.array[latestY.array.length - 1];
        // Calculate speed
        const speed = Math.sqrt(avgVx * avgVx + avgVy * avgVy);
        // If speed is very low, assume target is stationary
        const SPEED_THRESHOLD = 1; // Puedes ajustar este valor según el juego
        if (speed < SPEED_THRESHOLD) {
            return { x: currentX, y: currentY };
        }
        // Predict future position
        const predictedX = currentX + avgVx * timeToPredictSeconds;
        const predictedY = currentY + avgVy * timeToPredictSeconds;
        return { x: predictedX, y: predictedY };
    }
