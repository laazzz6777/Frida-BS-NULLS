            dodgeState.lastInput = { x, y, time: now };
            if (isDodge) {
                dodgeState.currentDodge = { x, y };
            }
        } catch (e) {}
    }
    function analyzeProjectiles(objects, count, myTeamId, myX, myY, myRadius) {
        const now = Date.now();
        const currentIds = new Set();
        const threats = [];
        for (let i = 0; i < count; i++) {
            try {
                const objPtr = objects.add(i * 8).readPointer();
                if (!objPtr || objPtr.isNull()) continue;
                const dataPtr = natives.LogicGameObjectClient_getData(objPtr);
                if (!dataPtr || dataPtr.isNull()) continue;
                const vtable = dataPtr.readPointer();
                if (!vtable.equals(PTR_VTABLE_PROJECTILE_DATA)) continue;
                const id = natives.LogicGameObjectClient_getGlobalID(objPtr).toString();
                currentIds.add(id);
                const teamId = objPtr.add(64).readU32();
                const stateFlag = objPtr.add(208).readU32();
                if (teamId === myTeamId || stateFlag !== 0) {
                    dodgeState.projectiles.delete(id);
                    continue;
                }
                const x = natives.LogicGameObjectClient_getX(objPtr);
                const y = natives.LogicGameObjectClient_getY(objPtr);
                const speed = natives.LogicProjectileData_getSpeed(dataPtr);
                const radius = natives.LogicProjectileData_getRadius(dataPtr);
                const prev = dodgeState.projectiles.get(id) || {};
                let angle = prev.angle;
                let calculated = prev.calculated;
                if (prev.x !== undefined) {
                    const dx = x - prev.x, dy = y - prev.y;
                    if (dx * dx + dy * dy > DODGE_CONFIG.ANGLE_DETECTION_THRESHOLD) {
                        angle = Math.atan2(dy, dx);
                        calculated = true;
                    }
                }
                dodgeState.projectiles.set(id, {
                    x, y, speed, radius, angle, calculated, lastSeen: now
                });
                if (speed > DODGE_CONFIG.MIN_PROJECTILE_SPEED && calculated) {
                    const ttc = timeToCollision({ x, y, speed, radius, angle }, myX, myY, myRadius);
                    if (ttc < DODGE_CONFIG.PREDICTION_TIME) {
                        threats.push({ id, x, y, speed, radius, angle, ttc });
                    }
                }
            } catch (e) { continue; }
        }
        for (const id of dodgeState.projectiles.keys()) {
            const p = dodgeState.projectiles.get(id);
            if (!currentIds.has(id) || now - p.lastSeen > DODGE_CONFIG.STALE_PROJECTILE_THRESHOLD) {
                dodgeState.projectiles.delete(id);
            }
        }
        return threats;
    }
    function timeToCollision(proj, myX, myY, myRadius) {
        const relX = proj.x - myX;
        const relY = proj.y - myY;
        const relVelX = Math.cos(proj.angle) * proj.speed;
        const relVelY = Math.sin(proj.angle) * proj.speed;
        const a = relVelX * relVelX + relVelY * relVelY;
        const b = 2 * (relX * relVelX + relY * relVelY);
        const c = relX * relX + relY * relY - (proj.radius + myRadius + DODGE_CONFIG.COLLISION_MARGIN) ** 2;
        const discriminant = b * b - 4 * a * c;
        if (discriminant < 0) return Infinity;
        const t1 = (-b - Math.sqrt(discriminant)) / (2 * a);
        const t2 = (-b + Math.sqrt(discriminant)) / (2 * a);
        if (t1 >= 0) return t1;
        if (t2 >= 0) return t2;
        return Infinity;
    }
    function calculateBestDodge(threats, myX, myY, myRadius) {
        if (threats.length === 0) return null;
        const mainThreat = threats.reduce((a, b) => a.ttc < b.ttc ? a : b);
        const perpendicular1 = mainThreat.angle + Math.PI / 2;
        const perpendicular2 = mainThreat.angle - Math.PI / 2;
        const options = [
            { x: myX + Math.cos(perpendicular1) * DODGE_CONFIG.DODGE_DISTANCE, y: myY + Math.sin(perpendicular1) * DODGE_CONFIG.DODGE_DISTANCE, angle: perpendicular1, score: 0 },
            { x: myX + Math.cos(perpendicular2) * DODGE_CONFIG.DODGE_DISTANCE, y: myY + Math.sin(perpendicular2) * DODGE_CONFIG.DODGE_DISTANCE, angle: perpendicular2, score: 0 }
        ];
        options.forEach(option => {
            threats.forEach(threat => {
                const futureX = threat.x + Math.cos(threat.angle) * threat.speed * threat.ttc;
                const futureY = threat.y + Math.sin(threat.angle) * threat.speed * threat.ttc;
                const dist = Math.sqrt((option.x - futureX) ** 2 + (option.y - futureY) ** 2);
                const safeDist = threat.radius + myRadius + DODGE_CONFIG.COLLISION_MARGIN;
                if (dist > safeDist) {
                    option.score += (dist - safeDist) * (1 / (threat.ttc + 0.1));
                } else {
                    option.score -= (safeDist - dist) * 10;
                }
            });
        });
        const bestOption = options.reduce((a, b) => a.score > b.score ? a : b);
        if (bestOption.score < 0 && DODGE_CONFIG.DODGE_DIRECTION_OVERRIDE) {
            return options[Math.random() > 0.5 ? 0 : 1];
        }
        return bestOption;
    }
    function executeForceDodge(targetX, targetY) {
